{
  "name": "@jordonh18/fastmail-connector",
  "version": "1.0.0",
  "description": "MCP connector for Fastmail — enables Claude to read, search, send, and manage emails via the JMAP protocol",
  "type": "module",
  "bin": {
    "fastmail-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "author": "jordonh18",
  "keywords": [
    "mcp",
    "fastmail",
    "jmap",
    "email",
    "claude"
  ]
}
